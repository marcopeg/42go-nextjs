# Example Database Connection Strings
# -------------------------------------
# Uncomment the one you want to use. For local development, SQLite is the simplest.

# PostgreSQL
# DBSTRING="postgres://user:password@host:port/database"
DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres"

# Bacup and Restore Database Connection Strings
# ---------------------------------------------
# Required for backup/restore capabilities.
# These are willingly separated from DATABASE_URL to allow using a different database/user with lower permissions for backup/restore operations, as recommended by best practices.
BACKUP_DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres"
RESTORE_DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres"

# Core Events Export
# ------------------
# Required by .agents/skills/42go-events-export/scripts/export_events.py.
EVENTS_DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres"
# EVENTS_ANALYTICS_DIR=".local/42go-events"

# NextAuth.js Configuration
# -------------------------
# Required for NextAuth.js authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# GitHub OAuth Configuration
# ---------------------------
# Get these from GitHub Developer Settings > OAuth Apps
# For development: Authorization callback URL = http://localhost:3000/api/auth/callback/github
# For production: Authorization callback URL = https://yourdomain.com/api/auth/callback/github
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Google OAuth Configuration
# ---------------------------
# Get these from Google Cloud Console > APIs & Services > Credentials
# For development: Authorized redirect URI = http://localhost:3000/api/auth/callback/google
# For production: Authorized redirect URI = https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# LingoCafe Static Assets
# -----------------------
# Optional. Defaults to https://assets.lingocafe.app when unset.
LC_ASSETS_BASE_PATH="https://assets.lingocafe.app"

# CapRover Deployment
# -------------------
# Optional. Used by `make deploy` and `make deploy.nocache`.
# CAPROVER_URL="https://captain.example.com"
# CAPROVER_APP="a42go-multi"
# CAPROVER_APP_TOKEN="your-caprover-app-token"
